{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "alipaysdk/easysdk": "^2.2",
        "awcodes/filament-quick-create": "^5.0",
        "bezhansalleh/filament-language-switch": "^4.2",
        "bezhansalleh/filament-shield": "^4.2",
        "charrafimed/global-search-modal": "^5.0",
        "codewithdennis/filament-select-tree": "4.x",
        "eduardoribeirodev/filament-leaflet": "^4.7",
        "endroid/qr-code": "^6.1",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-media-library-plugin": "^5.0",
        "filament/spatie-laravel-settings-plugin": "^5.0",
        "filament/spatie-laravel-tags-plugin": "^5.0",
        "hugomyb/filament-media-action": "^5.0",
        "kalnoy/nestedset": "^v7.0.1",
        "knuckleswtf/scribe": "^5.8",
        "laravel/ai": "^v0.5.1",
        "laravel/cashier": "^16.3",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.34",
        "laravel/octane": "^2.17",
        "laravel/scout": "^11",
        "laravel/socialite": "^5.24",
        "laravel/tinker": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.32",
        "maatwebsite/excel": "^3.1",
        "malzariey/filament-daterangepicker-filter": "^5.0",
        "meilisearch/meilisearch-php": "^1.16",
        "opcodesio/log-viewer": "^3.21",
        "resend/resend-php": "^1.1",
        "spatie/laravel-activitylog": "^5.0.0",
        "spatie/laravel-backup": "^10.1",
        "spatie/laravel-medialibrary": "^11.21",
        "spatie/laravel-query-builder": "^7.0.0",
        "spatie/laravel-responsecache": "^8.2",
        "spiral/roadrunner-cli": "^2.7.2",
        "spiral/roadrunner-http": "^4.1.0",
        "tymon/jwt-auth": "^2.3",
        "wechatpay/wechatpay": "^1.4"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "fakerphp/faker": "^1.23",
        "lanin/laravel-api-debugger": "^4.0",
        "laravel-lang/lang": "^15.29",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-stressless": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
